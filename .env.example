# ============================================================
# MetroVision AI — Variáveis de Ambiente (Template)
# ============================================================
# Copie este arquivo como .env e preencha com suas credenciais.
#   cp .env.example .env
#
# NUNCA suba o arquivo .env real para o repositório.

# Token de acesso ao HuggingFace (necessário para baixar pesos do SAM 3.1)
# Obtenha em: https://huggingface.co/settings/tokens
HF_TOKEN=hf_SEU_TOKEN_AQUI

# Caminho absoluto para a instalação local do SAM 3.1
# Exemplo Windows: C:\Users\seu_usuario\sam3
# Exemplo Linux:   /home/seu_usuario/sam3
SAM3_PATH=/caminho/para/sam3
